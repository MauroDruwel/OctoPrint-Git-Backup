<form class="form-horizontal">

    <div class="alert alert-warning" style="margin-bottom:16px">
        <i class="fas fa-lock"></i>
        <strong>{{ _('Use a private repository') }}</strong>,
        {{ _('backups may contain API keys, plugin settings, and credentials.') }}
    </div>

    <!-- Repository URL -->
    <div class="control-group">
        <label class="control-label">{{ _('Repository URL') }}</label>
        <div class="controls">
            <input type="text"
                   class="input-block-level"
                   id="git_backup_repo_url_input"
                   data-bind="value: settings.plugins.git_backup.repo_url"
                   placeholder="https://github.com/user/octoprint-backup.git">
            <span id="git_backup_repo_check" class="help-block" style="margin-top:4px"></span>
            <span class="help-block">{{ _('HTTPS (recommended) or SSH URL of your GitHub repository.') }}</span>
        </div>
    </div>

    <!-- Options -->
    <div class="control-group">
        <label class="control-label">{{ _('Options') }}</label>
        <div class="controls">
            <label class="checkbox">
                <input type="checkbox" data-bind="checked: settings.plugins.git_backup.delete_backup_after_push">
                {{ _('Delete local backup after a successful push') }}
            </label>
            <span class="help-block">{{ _('Removes the .zip from OctoPrint once it has been pushed.') }}</span>
        </div>
    </div>

    <!-- Authentication -->
    <div class="control-group">
        <label class="control-label">{{ _('Authentication') }}</label>
        <div class="controls">
            <p class="help-block" style="margin:0 0 6px">
                <i class="fas fa-info-circle"></i>
                {{ _('No credentials are stored, auth is configured once at the OS level.') }}
            </p>
            <ul class="help-block" style="margin:0 0 4px; padding-left:18px">
                <li>
                    <strong>{{ _('Recommended:') }}</strong>
                    {{ _('HTTPS URL +') }}
                    <a href="https://cli.github.com" target="_blank" rel="noopener noreferrer">{{ _('GitHub CLI') }}</a>
                   , {{ _('run') }} <code>gh auth login</code> {{ _('once on your Pi.') }}
                </li>
                <li>
                    <strong>{{ _('Alternative:') }}</strong>
                    {{ _('SSH URL +') }}
                    <a href="https://docs.github.com/en/authentication/connecting-to-github-with-ssh" target="_blank" rel="noopener noreferrer">{{ _('SSH key') }}</a>
                    (<code>git@github.com:user/repo.git</code>)
                </li>
            </ul>
        </div>
    </div>

    <!-- Auth / Setup Status -->
    <div class="control-group">
        <label class="control-label">{{ _('Status') }}</label>
        <div class="controls">
            <div id="git_backup_auth_status" style="margin-bottom:8px">
                <span class="muted">{{ _('Not checked yet.') }}</span>
            </div>
            <button class="btn btn-small" id="git_backup_auth_refresh"
                    data-bind="click: function() { OctoPrint.plugins.git_backup.checkAuthStatus(); }">
                <i class="fas fa-sync-alt"></i> {{ _('Refresh') }}
            </button>
        </div>
    </div>

    <!-- Tips -->
    <div class="control-group">
        <label class="control-label">{{ _('Tips') }}</label>
        <div class="controls">
            <ul class="help-block" style="margin:0; padding-left:18px">
                <li>
                    {{ _('Exclude <strong>timelapses</strong> and <strong>uploads</strong> from OctoPrint backups to keep your repo small, GitHub rejects files over 100 MB') }}
                   , {{ _('do this in') }}
                    <strong>{{ _('Settings → Backup & Restore → Create backup') }}</strong>.
                </li>
                <li>
                    {{ _('Want beautiful timelapses?') }}
                    <a href="https://plugins.octoprint.org/plugins/youtube_timelapse/" target="_blank" rel="noopener noreferrer">YouTube Timelapse</a>
                    {{ _('uploads them directly to YouTube and keeps them out of your backup entirely.') }}
                </li>
                <li>
                    {{ _('Back up on a schedule?') }}
                    <a href="https://plugins.octoprint.org/plugins/backup_scheduler/" target="_blank" rel="noopener noreferrer">{{ _('Backup Scheduler') }}</a>
                    {{ _('triggers OctoPrint backups automatically, this plugin will push each one.') }}
                </li>
            </ul>
        </div>
    </div>

</form>
